# Frontend (React + Vite)
# Copie para frontend/.env quando quiser rodar frontend isolado

# Supabase (cliente publico)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Modelo NVIDIA no frontend
VITE_NVIDIA_API_KEY=""
VITE_NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
VITE_LLM_MODEL="z-ai/glm4.7"

# URL do Agent para chamadas do frontend
PYTHON_AGENT_URL="http://localhost:8000"
PYTHON_AGENT_URI=""

# Opcional: comportamento do HMR no Vite
DISABLE_HMR="false"
