# Gemini API (Legacy)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Application URL
APP_URL="MY_APP_URL"

# Server Configuration
PORT=3000
NODE_ENV=development
DEBUG=false

# Python Agent Configuration
PYTHON_AGENT_URL="http://localhost:8000"

# For production (Vercel + Railway):
# PYTHON_AGENT_URL=https://seu-agent.railway.app

# Supabase Configuration (for agent persistence)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Claude API (Optional - Agent can use this)
ANTHROPIC_API_KEY="your_api_key"

# NVIDIA API (for GLM model)
VITE_NVIDIA_API_KEY="your_nvidia_key"
VITE_NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
VITE_LLM_MODEL="z-ai/glm4.7"

