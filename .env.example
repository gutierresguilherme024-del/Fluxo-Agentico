# =====================================================
# Fluxo Agentico - Template de variaveis de ambiente
# Copie para .env e preencha os valores reais
# =====================================================

# --- LLM (obrigatorio: pelo menos UMA chave) ---
# Opcao 1 (recomendada no projeto): NVIDIA
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
LLM_MODEL="z-ai/glm4.7"

# Opcao 2 (fallback): Anthropic
ANTHROPIC_API_KEY=""

# --- Supabase (recomendado para memoria persistente) ---
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
# Opcional: se informado, o agent prioriza esta chave
SUPABASE_SERVICE_ROLE_KEY=""

# --- Agent API (opcional, defaults internos ja funcionam) ---
AGENT_HOST="0.0.0.0"
AGENT_PORT="8000"
# Aliases tambem aceitos pelo backend
HOST="0.0.0.0"
PORT="8000"
CHROMA_PATH="./chroma_db"
CHROMA_TIMEOUT="30"

# --- Frontend local (Vite) ---
# Usado quando rodar frontend fora do Docker
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
VITE_NVIDIA_API_KEY=""
VITE_NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
VITE_LLM_MODEL="z-ai/glm4.7"
# Vite usa isso no ambiente de edicao AI Studio
DISABLE_HMR="false"

# --- API Proxy (Vercel/Node) ---
# URL publica do Agent para /api/chat e /api/status
PYTHON_AGENT_URL="http://localhost:8000"
# Alias aceito pelo codigo
PYTHON_AGENT_URI=""

# --- Legado/compatibilidade (opcional) ---
GEMINI_API_KEY=""
APP_URL=""
