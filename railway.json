{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
    },
    "deploy": {
        "healthcheckPath": "/",
        "healthcheckTimeout": 120,
        "healthcheckInterval": 20,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5,
        "numReplicas": 1,
        "startCommand": "echo '[RAILWAY START]' && python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080} --workers 1 --log-level info"
    }
}