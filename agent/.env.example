# Agent (Python + FastAPI)
# Copie para agent/.env quando quiser rodar agent isolado

# LLM (preencha ao menos uma chave)
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
LLM_MODEL="z-ai/glm4.7"

# Fallback Anthropic
ANTHROPIC_API_KEY=""

# Supabase (persistencia)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Runtime do agent
AGENT_HOST="0.0.0.0"
AGENT_PORT="8000"
HOST="0.0.0.0"
PORT="8000"
CHROMA_PATH="./chroma_db"
CHROMA_TIMEOUT="30"
